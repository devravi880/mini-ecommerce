PORT=5001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
# If password contains special characters (@, #, etc.), URL-encode them
# Example: password "ravi@123" becomes "ravi%40123"
DATABASE_URL="mysql://root:password@localhost:3306/shopsphere"

# JWT (configured in Step 6)
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d
